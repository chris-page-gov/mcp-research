# Normalize text files to LF on every platform.
* text=auto eol=lf

# Project text sources
*.md text eol=lf
*.txt text eol=lf
*.py text eol=lf
*.sh text eol=lf
Makefile text eol=lf
*.tex text eol=lf
*.bib text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.lock text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Future TypeScript/frontend files
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.svg text eol=lf

# Binary/document artifacts
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.docx binary
*.pptx binary
*.xlsx binary
*.zip binary
